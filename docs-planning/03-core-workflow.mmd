                P4_CHECK["校验器检查:<br/>· 路径保护规则<br/>· 文件属性<br/>· 进程持有检测<br/>· 权限合规性"]
                P4_BRANCH{"校验结果"}
                P4_BLOCK["🚫 BLOCKED<br/>命中保护规则<br/>跳过+警告"]
                P4_WARN["⚠️ WARNING<br/>进程持有<br/>需人工确认"]
                P4_ESC["🔑 ESCALATE<br/>权限不足<br/>sudo白名单检查"]
                P4_PASS["✅ PASSED<br/>全部通过<br/>放行执行"]
            end

            subgraph PHASE5["阶段5：权限审查与执行"]
                P5["最小权限执行引擎<br/>账户: devops-runner<br/>命令白名单 + sudo 限制<br/>subprocess 调用 → Linux FS"]
            end

            subgraph PHASE6["阶段6：结果汇总"]
                P6A["捕获执行输出<br/>成功/失败/部分成功"]
                P6B["LLM 生成<br/>自然语言总结回复"]
