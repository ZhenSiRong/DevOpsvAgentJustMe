    %% 层间主流程
    User -->|"POST {message}"| R1
    R1 --> P1
    P1 --> P2A
    
    %% 阶段2 内部流程
    P2A --> P2B --> P2C --> P2D
    P2D -- "是" --> P2A
    P2D -- "否" --> P2E
    P2E --> P3
    
    %% 阶段3 → 阶段4
    P3 -->|"tool_use 操作列表"| P4_LOOP
    P4_LOOP --> P4_CHECK
    P4_CHECK --> P4_BRANCH
    
    %% 安全校验分支
    P4_BRANCH -- "路径命中保护规则" --> P4_BLOCK
    P4_BRANCH -- "被活跃进程持有" --> P4_WARN
    P4_BRANCH -- "权限不足" --> P4_ESC
    P4_BRANCH -- "全部通过" --> P4_PASS
    
    P4_BLOCK -->|"记录并跳过"| P5
    P4_WARN -->|"等待确认后放行/拒绝"| P5
    P4_ESC -->|"白名单内→放行 / 外→拒绝"| P5
    P4_PASS -->|"放行"| P5
    
    %% 阶段5 执行
    P5 -->|"subprocess(cmd, user=devops-runner)"| FS
    FS -->|"exit_code + output"| P5
    P5 --> P6A
    
    %% 阶段6 汇总
    P6A --> P6B --> P6C
    P6C -->|"StreamResponse chunks"| WS
    WS -->|"SSE 流式推送"| UI
    UI -->|"展示回复 + 审计日志"| User
    
    %% 数据库写入（贯穿全程）
    P1 -.->|"audit_log: received"| DB_SQLite
    P4_CHECK -.->|"audit_log: security_check"| DB_SQLite
    P5 -.->|"audit_log: execution"| DB_SQLite
    P6C -.->|"audit_log: response_ready"| DB_SQLite
    UI -.->|"GET audit-logs"| R2
    R2 -.->|查询| DB_SQLite

    %% 探针调用文件系统
    P2A -.->|subprocess| FS
    P2B -.->|subprocess| FS
    P2C -.->|subprocess| FS

