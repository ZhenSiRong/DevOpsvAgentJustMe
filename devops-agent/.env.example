# DevOps Agent - 环境配置
# 复制此文件为 .env 并填入实际值

# === 应用配置 ===
APP_NAME=DevOps-Agent
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# === LLM 配置（二选一） ===
LLM_PROTOCOL=openai  # openai | anthropic
LLM_BASE_URL=https://api.deepseek.com/v1  # DeepSeek / OpenAI 兼容地址
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# === Anthropic 协议备用（当 LLM_PROTOCOL=anthropic 时启用） ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === 数据库 ===
DATABASE_URL=sqlite+aiosqlite:///./data/devops_agent.db

# === 安全层 ===
# 受限执行账户
SAFE_EXEC_USER=devops-runner
# 命令超时（秒）
EXEC_TIMEOUT=30
# sudo 白名单命令（逗号分隔，* 通配符允许参数）
SUDO_WHITELIST=logrotate,systemctl status,systemctl restart,journalctl,df,du,ps,netstat,ss,cat,ls,find,grep,head,tail,wc,sort,uniq,cut,awk,sed

# === 认证（MVP 可选）===
JWT_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24h

# === 探针配置 ===
PROBE_TIMEOUT=10  # 单次探针超时秒数
PROBE_MAX_ROUNDS=5  # Agent 感知循环最大轮次
